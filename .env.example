# Copy to .env for local development. Real environment variables always win.
# These map to the go-flags options in app/config/opts.go (group env-namespaces).
SERVICE_NAME=skit-example
APP_ENV=development
LOG_LEVEL=info

# REST, gRPC and the status server each start iff their *_ADDR is set; clear an
# address (e.g. HTTP_ADDR=) to turn that transport off.
HTTP_ADDR=:8080
HTTP_REQUEST_TIMEOUT=30s
HTTP_SHUTDOWN_TIMEOUT=10s

GRPC_ADDR=:9090
GRPC_REFLECTION=true

# grpc-gateway (JSON/HTTP proxy in front of gRPC, under /v1/widgets) on its own
# port; needs the gRPC server. Clear GATEWAY_ADDR= to disable it.
GATEWAY_ADDR=:8081

DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost:5432
DB_NAME=skit
DB_SCHEMA=public
# Off for local dev (local Postgres has no TLS). Set DB_TLS=true in production —
# the service refuses to start with APP_ENV=production and TLS off.
DB_TLS=false

# Tracing is off by default; enable with a collector on OTEL_ENDPOINT.
OTEL_ENABLED=false
OTEL_ENDPOINT=localhost:4317
OTEL_INSECURE=true
OTEL_PROBABILITY=1.0
